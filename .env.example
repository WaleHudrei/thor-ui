# ── Scraper service URLs ──────────────────────────────────────────────────
# Point at each Thor scraper Railway service. Leave blank to hide that
# scraper from the UI (useful during rollout).
THOR_MYCASE_URL=https://hudrei-scraper-production.up.railway.app
THOR_SRI_URL=https://thor-sri-production.up.railway.app

# ── Auth ──────────────────────────────────────────────────────────────────
# Set a password to enable basic auth. Leave blank to keep UI open (dev only).
APP_PASSWORD=

# Flask session secret — Railway auto-generates one if missing, but pinning it
# means sessions survive restarts.
SECRET_KEY=

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
